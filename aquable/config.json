{
  "name": "AquaBle",
  "version": "2.0.0",
  "slug": "aquable",
  "description": "Control Chihiros aquarium lights and dosing pumps over Bluetooth Low Energy",
  "url": "https://github.com/caleb-venner/aquable",
  "arch": ["armhf", "armv7", "aarch64", "amd64"],
  "startup": "application",
  "boot": "auto",
  "init": false,
  "host_network": true,
  "host_dbus": true,
  "privileged": ["SYS_ADMIN"],
  "hassio_api": true,
  "hassio_role": "default",
  "homeassistant_api": false,
  "ports": {
    "8000/tcp": 8000
  },
  "ports_description": {
    "8000/tcp": "Web interface and REST API"
  },
  "map": ["config:rw"],
  "options": {
    "auto_reconnect": true,
    "auto_discover": true,
    "status_wait_seconds": 1.5,
    "timezone": "auto"
  },
  "schema": {
    "auto_reconnect": "bool",
    "auto_discover": "bool",
    "status_wait_seconds": "float(0.5,5.0)?",
    "timezone": "str?"
  },
  "image": "ghcr.io/caleb-venner/{arch}-aquable"
}
